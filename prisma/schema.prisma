// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  TENANT
}

enum KostType {
  PUTRA
  PUTRI
  CAMPUR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED
  COMPLETED
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  phone         String?
  avatar        String?
  role          Role      @default(TENANT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  kosts         Kost[]
  bookings      Booking[]
  favorites     Favorite[]
  reviews       Review[]
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Kost {
  id          String    @id @default(cuid())
  name        String
  description String
  address     String
  city        String
  district    String
  province    String
  latitude    Float?
  longitude   Float?
  type        KostType  @default(CAMPUR)
  images      String[]
  facilities  String[]
  rules       String[]
  isActive    Boolean   @default(true)
  ownerId     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  owner       User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  rooms       Room[]
  bookings    Booking[]
  favorites   Favorite[]
  reviews     Review[]

  @@map("kosts")
}

model Room {
  id          String     @id @default(cuid())
  name        String
  description String?
  price       Float
  priceYear   Float?
  size        String?
  floor       Int?
  status      RoomStatus @default(AVAILABLE)
  images      String[]
  facilities  String[]
  kostId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  kost        Kost      @relation(fields: [kostId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@map("rooms")
}

model Booking {
  id          String        @id @default(cuid())
  startDate   DateTime
  endDate     DateTime
  duration    Int           // in months
  totalPrice  Float
  status      BookingStatus @default(PENDING)
  notes       String?
  tenantId    String
  kostId      String
  roomId      String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  tenant      User   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kost        Kost   @relation(fields: [kostId], references: [id], onDelete: Cascade)
  room        Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  kostId    String
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kost      Kost     @relation(fields: [kostId], references: [id], onDelete: Cascade)

  @@unique([userId, kostId])
  @@map("favorites")
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String
  userId    String
  kostId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kost      Kost     @relation(fields: [kostId], references: [id], onDelete: Cascade)

  @@unique([userId, kostId])
  @@map("reviews")
}
